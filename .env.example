# Host port to serve Nyora on (default 8080).
WEB_PORT=8080

# Optional library-sync backend. Reading works fully offline without it.
#  - leave as-is to use the hosted Nyora Cloud,
#  - point at your own self-hosted nyora-sync-server (e.g. http://localhost:8000)
#    to stay 100% local,
#  - or ignore sync entirely and use the app as a guest.
NYORA_SYNC_URL=https://stream.hasanraza.tech

# Source refs the image is built from (branch / tag / commit).
NYORA_WEB_REF=main
NYORA_ENGINE_REF=main
